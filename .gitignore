# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Outreach lead lists. The GitHub repo is public (Pages free tier), and these
# hold real local businesses' phone numbers and emails — do not publish them.
# The generator script is fine to track; the CSVs are not.
leads/*.csv

# cloudflare worker
worker/node_modules
worker/.wrangler

# local tooling state (the .claude/rules + skills ARE tracked on purpose)
.claude/settings.local.json
.playwright-mcp/

# throwaway QA screenshots dropped in the repo root during development.
# Scoped to the root so public/assets/*.png stays tracked.
/*.png
